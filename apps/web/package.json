{
  "name": "graphboard-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "vite",
    "codegen": "graphql-codegen --config codegen.ts",
    "typecheck": "vue-tsc --noEmit",
    "build": "npm run codegen && npm run typecheck && vite build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@apollo/client": "^3.13.0",
    "@vue/apollo-composable": "^4.2.0",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/typed-document-node": "^5.1.0",
    "@graphql-codegen/typescript": "^4.1.0",
    "@graphql-codegen/typescript-operations": "^4.6.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "typescript": "~5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0",
    "vue-tsc": "^3.0.0"
  }
}
